{
  "version": 2,
  "buildCommand": "npm run build",
  "routes": [
    {
      "src": "/api-docs",
      "status": 308,
      "headers": {
        "Location": "/api/docs/"
      }
    },
    {
      "src": "/api-docs/",
      "dest": "/api/docs.js"
    },
    {
      "src": "/api-docs/(.*)",
      "dest": "/api/docs.js"
    },
    {
      "src": "/docs",
      "status": 308,
      "headers": {
        "Location": "/api/docs/"
      }
    },
    {
      "src": "/docs/",
      "status": 308,
      "headers": {
        "Location": "/api/docs/"
      }
    },
    {
      "src": "/api/docs",
      "status": 308,
      "headers": {
        "Location": "/api/docs/"
      }
    },
    {
      "src": "/api/docs/",
      "dest": "/api/docs.js"
    },
    {
      "src": "/api/docs/(.*)",
      "dest": "/api/docs.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
