# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Configuration
# Generate a secure random string for JWT signing
JWT_SECRET=your-secure-jwt-secret-here

# SMTP Configuration for reset code emails
# Example: Gmail App Password, SendGrid SMTP, Mailgun SMTP, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=MyTrancy

# Supabase Edge Function (Resend) configuration for reset code emails
# If set, backend will call this function first for email delivery.
# Defaults to ${SUPABASE_URL}/functions/v1/send-reset-code when omitted.
RESET_CODE_FUNCTION_URL=
# Function key used in apikey/Authorization (service role recommended)
RESET_CODE_FUNCTION_KEY=

# Server Configuration (optional)
# Default port is 5000
PORT=5000