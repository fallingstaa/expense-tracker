{
  "version": 2,
  "installCommand": "npm install && npm --prefix frontend install",
  "buildCommand": "npm --prefix frontend run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/docs",
      "dest": "/api/docs.js"
    },
    {
      "src": "/api/docs/(.*)",
      "dest": "/api/docs.js"
    },
    {
      "src": "/api",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
